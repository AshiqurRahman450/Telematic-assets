extends layout

block content
  .d-flex.justify-content-between.align-items-center.pb-3.mb-4.border-bottom(style="border-color: var(--glass-border) !important")
    div
      h1.h2.fw-bold.mb-1 Issue Asset
      p.text-secondary.mb-0 Hand over an available stock item to an active employee
    a.btn.btn-outline-light(href="/assets" style="border-color: var(--glass-border)")
      i.fa-solid.fa-arrow-left.me-2
      | Cancel

  if success_msg
    .alert.alert-success.alert-dismissible.fade.show.border-0.text-light(role="alert" style="background: rgba(34, 197, 94, 0.2)")
      i.fa-solid.fa-check-circle.me-2
      span= success_msg
      button.btn-close.btn-close-white(type="button" data-bs-dismiss="alert" aria-label="Close")

  if error_msg
    .alert.alert-danger.alert-dismissible.fade.show.border-0.text-light(role="alert" style="background: rgba(239, 68, 68, 0.2)")
      i.fa-solid.fa-exclamation-triangle.me-2
      span= error_msg
      button.btn-close.btn-close-white(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-lg-8
      .glass-card
        form(action="/operations/issue", method="POST")
          .mb-4
            label.form-label(for="assetId") Select Available Asset
            select#assetId.form-select(name="assetId", required=true)
              option(value="" selected=true disabled=true) -- Select an Asset in Stock --
              each asset in assets
                option(value=asset.id)= `${asset.uniqueId} - ${asset.make} ${asset.model} (SN: ${asset.serialNumber}, Branch: ${asset.branch}, Value: $${asset.value})`
            .form-text.text-secondary Only assets currently in 'Stock' status are displayed.

          .mb-4
            label.form-label(for="employeeId") Assign to Employee
            select#employeeId.form-select(name="employeeId", required=true)
              option(value="" selected=true disabled=true) -- Select an Active Employee --
              each emp in employees
                option(value=emp.id)= `${emp.employeeId} - ${emp.name} (Location: ${emp.branch}, Dept: ${emp.email})`
            .form-text.text-secondary Only 'Active' employees are eligible to receive assets.

          .mb-4
            label.form-label(for="issueDate") Date of Issue
            input#issueDate.form-control(type="date", name="issueDate", value=new Date().toISOString().split('T')[0], required=true)

          .mb-4
            label.form-label(for="notes") Issue Notes (Optional)
            textarea#notes.form-control(name="notes", rows="3", placeholder="e.g. Project setup, standard laptop issue...")

          .d-flex.gap-2.mt-4
            button.btn.btn-primary-custom(type="submit")
              i.fa-solid.fa-handshake.me-2
              | Issue Asset
            a.btn.btn-outline-light(href="/" style="border-color: var(--glass-border)") Cancel
