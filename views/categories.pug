extends layout

block content
  .d-flex.justify-content-between.align-items-center.pb-3.mb-4.border-bottom(style="border-color: var(--glass-border) !important")
    div
      h1.h2.fw-bold.mb-1 Asset Categories
      p.text-secondary.mb-0 Manage the various hardware categories in the system
    a.btn.btn-primary-custom(href="/categories/new")
      i.fa-solid.fa-plus.me-2
      | Add Category

  if success_msg
    .alert.alert-success.alert-dismissible.fade.show.border-0.text-light(role="alert" style="background: rgba(34, 197, 94, 0.2)")
      i.fa-solid.fa-check-circle.me-2
      span= success_msg
      button.btn-close.btn-close-white(type="button" data-bs-dismiss="alert" aria-label="Close")

  if error_msg
    .alert.alert-danger.alert-dismissible.fade.show.border-0.text-light(role="alert" style="background: rgba(239, 68, 68, 0.2)")
      i.fa-solid.fa-exclamation-triangle.me-2
      span= error_msg
      button.btn-close.btn-close-white(type="button" data-bs-dismiss="alert" aria-label="Close")

  .glass-card
    table.table.datatables.w-100
      thead
        tr
          th Category ID
          th Name
          th Assets Count
          th Actions
      tbody
        each cat in categories
          tr
            td= cat.id
            td
              strong.text-light= cat.name
            td
              span.badge.bg-dark.text-secondary.px-2.py-1= cat.assets ? cat.assets.length : 0
            td
              a.btn.btn-sm.btn-outline-indigo.me-2(href=`/categories/edit/${cat.id}` style="border-color: var(--glass-border); color: #818cf8; transition: all 0.2s")
                i.fa-solid.fa-pen-to-square.me-1
                | Edit
