extends layout

block content
  .d-flex.justify-content-between.align-items-center.pb-3.mb-4.border-bottom(style="border-color: var(--glass-border) !important")
    div
      h1.h2.fw-bold.mb-1= category ? 'Edit Category' : 'Add Category'
      p.text-secondary.mb-0= category ? `Modify details for category "${category.name}"` : 'Define a new asset category type'
    a.btn.btn-outline-light(href="/categories" style="border-color: var(--glass-border)")
      i.fa-solid.fa-arrow-left.me-2
      | Back to Categories

  if error_msg
    .alert.alert-danger.alert-dismissible.fade.show.border-0.text-light(role="alert" style="background: rgba(239, 68, 68, 0.2)")
      i.fa-solid.fa-exclamation-triangle.me-2
      span= error_msg
      button.btn-close.btn-close-white(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row
    .col-lg-6
      .glass-card
        form(action=category ? `/categories/edit/${category.id}` : '/categories/new', method="POST")
          .mb-4
            label.form-label(for="name") Category Name
            input#name.form-control(type="text", name="name", placeholder="e.g. Laptop, Mobile Phone, Screw Driver", value=category ? category.name : '', required=true)
            .form-text.text-secondary Specify a unique descriptive name for the hardware type.
          
          .d-flex.gap-2.mt-4
            button.btn.btn-primary-custom(type="submit")
              i.fa-solid.fa-save.me-2
              | Save Category
            a.btn.btn-outline-light(href="/categories" style="border-color: var(--glass-border)") Cancel
